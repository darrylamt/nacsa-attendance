{
  "expo": {
    "name": "NACSA Attendance",
    "slug": "nacsa-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nacsa.attendance",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to verify you are at your office before clocking in.",
        "NSCameraUsageDescription": "Camera is used for facial recognition when clocking in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.nacsa.attendance",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to verify you are at your office before clocking in."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used for facial recognition when clocking in."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#CC0000",
          "sounds": []
        }
      ]
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "eas": {
        "projectId": "de55f19b-acad-4f72-9d05-317fc4371efa"
      }
    }
  }
}
